{
	"name": "bw-hspc-contest-web",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && prisma generate && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --incremental",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . --cache && eslint . --cache",
		"format": "prettier --write . --cache",
		"pre-commit": "npm run format; npm run lint; npm run check"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/bcrypt": "^6.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bootstrap": "^5.2.10",
		"@types/js-cookie": "^3.0.6",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"drizzle-kit": "^1.0.0-beta.19",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"npm-check-updates": "^19.6.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.98.0",
		"sv": "^0.13.0",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2"
	},
	"type": "module",
	"dependencies": {
		"@prisma/client": "^7.5.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@types/fs-extra": "^11.0.4",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.8.0",
		"bootstrap": "^5.3.8",
		"bootstrap-icons": "^1.13.1",
		"bwcontest-shared": "file:../shared",
		"diff": "^8.0.4",
		"diff2html": "^3.4.56",
		"drizzle-orm": "^1.0.0-beta.19",
		"eslint-plugin-svelte": "^3.16.0",
		"fs-extra": "^11.3.4",
		"highlight.js": "^11.11.1",
		"isomorphic-git": "^1.37.4",
		"js-cookie": "^3.0.5",
		"memfs": "^4.57.1",
		"node-git-server": "^1.0.0",
		"prisma": "^7.5.0",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	}
}
