{
	"name": "bwcontest-shared",
	"scripts": {
		"build": "rimraf --glob dist/* && tsc",
		"watch": "rimraf --glob dist/* && tsc --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "tsc -noEmit",
		"pre-commit": "npm run format; npm run lint; npm run check"
	},
	"type": "commonjs",
	"exports": {
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		}
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "25.x",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2"
	},
	"dependencies": {
		"fs-extra": "^11.3.4",
		"tree-kill": "^1.2.2",
		"zod": "^4.3.6"
	}
}
