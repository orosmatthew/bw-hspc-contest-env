{
	"name": "sandbox",
	"private": true,
	"scripts": {
		"build": "rimraf --glob dist/* && tsc",
		"watch": "tsc  --watch",
		"check": "tsc -noEmit",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"start": "node ./dist/index.js",
		"pre-commit": "npm run format; npm run lint; npm run check"
	},
	"type": "module",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2"
	},
	"dependencies": {
		"bwcontest-shared": "file:../shared",
		"dotenv": "^17.3.1",
		"fs-extra": "^11.3.4",
		"globals": "^17.4.0",
		"simple-git": "^3.33.0",
		"tree-kill": "^1.2.2",
		"url-join": "^5.0.0",
		"zod": "^4.3.6"
	}
}
