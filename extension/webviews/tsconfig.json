{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"exclude": ["../node_modules/*"],
	"compilerOptions": {
		"target": "es2024",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["es2024", "DOM"],
		"strict": true,
		"sourceMap": true,
		"rootDirs": [".", "../shared"]
	},
	"include": ["./**/*"]
}
